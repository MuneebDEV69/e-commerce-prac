# ─── Admin-panel — production env ───────────────────────────────────────────
# Base URL of the deployed A-Backend API (Render). Local dev: http://127.0.0.1:4000
API_URL="https://your-backend.onrender.com"

# Supabase (admin auth) — safe to expose (public anon key)
NEXT_PUBLIC_SUPABASE_URL="https://PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"

# Deployed storefront URL — used for "view on store" links. Local: http://localhost:3000
NEXT_PUBLIC_STOREFRONT_URL="https://your-store.vercel.app"
