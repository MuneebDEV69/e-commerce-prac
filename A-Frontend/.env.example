# ─── A-Frontend (storefront) — production env ───────────────────────────────
# Base URL of the deployed A-Backend API (Render). Local dev: http://127.0.0.1:4000
API_URL="https://your-backend.onrender.com"

# Supabase (customer auth + storage) — safe to expose (public anon key)
NEXT_PUBLIC_SUPABASE_URL="https://PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"
