# ─── A-Backend (Express API) — production env ───────────────────────────────
# PostgreSQL (Supabase). Runtime uses the pooler (6543); migrations use direct (5432).
DATABASE_URL="postgresql://postgres.PROJECT:PASSWORD@aws-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres:PASSWORD@db.PROJECT.supabase.co:5432/postgres"

# Supabase — used to verify user JWTs and look up roles
SUPABASE_URL="https://PROJECT.supabase.co"
SUPABASE_ANON_KEY="your-supabase-anon-key"

# CORS — the deployed storefront + admin origins (comma-free, one each)
FRONTEND_URL="https://your-store.vercel.app"
ADMIN_URL="https://your-admin.vercel.app"

# Render provides PORT automatically; 4000 is the local default
PORT=4000

# ─── PayFast (GoPayFast) — card payments ────────────────────────────────────
# Leave MERCHANT_ID/SECURED_KEY blank to keep card payments OFF (checkout falls
# back to placing a pending order). Fill them in to enable the hosted card flow.
PAYFAST_MODE="sandbox"          # "sandbox" (ipguat) or "live" (ipg1)
PAYFAST_MERCHANT_ID=""          # from your GoPayFast merchant dashboard
PAYFAST_SECURED_KEY=""          # from your GoPayFast merchant dashboard
PAYFAST_MERCHANT_NAME="Muneeb Ki Araish"
PAYFAST_STORE_ID=""             # optional, if your account uses store ids
# Public HTTPS URL of THIS backend (PayFast posts its callback here in production)
BACKEND_PUBLIC_URL="http://localhost:4000"

# ─── Email ──────────────────────────────────────────────────────────────────
# Hosts like Render's free tier BLOCK outbound SMTP, so use an HTTP provider.
# Priority: BREVO_API_KEY > RESEND_API_KEY > SMTP.
#
# BREVO (recommended when you have NO domain): sign up at brevo.com, verify ONE
# sender email (your Gmail — one click, no DNS), create an API key. Emails ALL users.
BREVO_API_KEY=""
# RESEND: sign up at resend.com. Emails arbitrary recipients ONLY after you verify
# a DOMAIN; otherwise its test sender reaches only your own account email.
RESEND_API_KEY=""

# Gmail SMTP (works locally; may be blocked on some hosts like Render free tier).
# Create an App Password at https://myaccount.google.com/apppasswords (needs 2FA).
SMTP_USER="you@gmail.com"
SMTP_PASS="your-16-char-app-password"     # no spaces
MAIL_FROM="Muneeb Ki Araish <you@gmail.com>"
ADMIN_EMAIL="you@gmail.com"                # where new-order / approval mails go
OTP_EXP_MIN=5                              # login code validity (minutes)
