# Copy to `.env` and fill in. Used by docker-compose.yml.

# --- Database (Supabase Postgres) ---
# Runtime uses the pooler (port 6543); migrations use the direct connection (5432).
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres"

# --- Supabase (server-side, backend token verification) ---
SUPABASE_URL="https://<project-ref>.supabase.co"
SUPABASE_ANON_KEY="<anon-key>"

# --- Supabase (browser, inlined into the Next apps at build time) ---
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="<anon-key>"
